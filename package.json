{
  "name": "markdown-to-vk",
  "version": "0.1.4",
  "description": "Markdown to VK format conversion pipeline",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean:dist": "node scripts/clean-dist.mjs",
    "build": "npm run clean:dist && tsc -p tsconfig.json && npm run check:dist",
    "check:dist": "node scripts/check-dist.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "demo": "npm run build && node tools/serve-demo.mjs",
    "validate:canvas": "npm run build && node tools/run-canvas-validation.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "index.js"
  ],
  "dependencies": {
    "@napi-rs/canvas": ">=0.1.46"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/parser": "^8.46.3",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.1",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "license": "MIT",
  "author": {
    "name": "Pavel Frankov",
    "url": "https://github.com/pfrankov"
  },
  "keywords": [
    "vk",
    "vkontakte",
    "markdown",
    "converter"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pfrankov/markdown-to-vk.git"
  },
  "bugs": {
    "url": "https://github.com/pfrankov/markdown-to-vk/issues"
  },
  "homepage": "https://github.com/pfrankov/markdown-to-vk#readme"
}
